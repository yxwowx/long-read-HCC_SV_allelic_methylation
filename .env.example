# Copy to .env and fill in with real paths for your environment.
# .env is gitignored; only this .env.example template is tracked.

# Root of raw + intermediate patient data (BAMs, DMR calls, SV annotations, results)
HCC_DATA_DIR=/path/to/hcc_data

# Root of shared reference/annotation files (GRCh38 fasta, ChIP-seq, Micro-C, etc.)
REFERENCE_DIR=/path/to/reference/GRCh38

# CSV mapping internal sample IDs to de-identified patient codes (P1..P12)
PATIENT_CODE_MAP=/path/to/patient_code_mapping.csv

# whatshap binary (only needed for 03_phasing_qc/phasing_quality.R)
WHATSHAP_BIN=whatshap

# UCSC hg19->hg38 liftover chain (only needed for 05_fragility_enrichment/replication_timing_admr.R)
LIFTOVER_CHAIN=/path/to/hg19ToHg38.over.chain
